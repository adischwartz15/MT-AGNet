# Kaggle API credentials (never commit a filled-in copy of this file).
# Create an API token at https://www.kaggle.com/settings -> "Create New Token"
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_DATASET_SLUG=

# Data source adapter: "utkface" (filename parser) or "csv" (generic CSV adapter)
DATASET_SOURCE=utkface

# Local paths (relative to repository root)
DATA_DIR=./data
CHECKPOINT_DIR=./checkpoints
OUTPUT_DIR=./outputs

# Dataset gender-label display names. These are DATASET labels, not
# determinations of gender identity. Only change them if your dataset's
# documentation defines what the two label values mean.
GENDER_LABEL_0=gender_label_0
GENDER_LABEL_1=gender_label_1

# Age range used for clamping model outputs
AGE_MIN=0
AGE_MAX=120

# Minimum softmax confidence required before a concrete dataset
# gender-label prediction is returned instead of "Not sure"
GENDER_CONFIDENCE_THRESHOLD=0.80
